# ----- Secrets (NEVER commit) -----
.env
.env.local
*.key
*.pem

# ----- Composer / vendor (regenerated by `composer install`) -----
/drupal-site/vendor/

# ----- Drupal core + contrib (composer-managed) -----
/drupal-site/web/core/
/drupal-site/web/modules/contrib/
/drupal-site/web/themes/contrib/
/drupal-site/web/profiles/contrib/
/drupal-site/web/libraries/

# ----- Drupal scaffold files (regenerated on `composer install`) -----
/drupal-site/.editorconfig
/drupal-site/.gitattributes
/drupal-site/LICENSE.txt
/drupal-site/recipes/
/drupal-site/scripts/
/drupal-site/web/.csslintrc
/drupal-site/web/.eslintignore
/drupal-site/web/.eslintrc.json
/drupal-site/web/.htaccess
/drupal-site/web/.ht.router.php
/drupal-site/web/autoload.php
/drupal-site/web/example.gitignore
/drupal-site/web/index.php
/drupal-site/web/INSTALL.txt
/drupal-site/web/README.md
/drupal-site/web/robots.txt
/drupal-site/web/update.php
/drupal-site/web/modules/README.txt
/drupal-site/web/profiles/README.txt
/drupal-site/web/sites/README.txt
/drupal-site/web/sites/development.services.yml
/drupal-site/web/sites/example.settings.local.php
/drupal-site/web/sites/example.sites.php
/drupal-site/web/themes/README.txt

# ----- Drupal runtime / per-environment files -----
/drupal-site/web/sites/default/files/
/drupal-site/web/sites/default/private/
/drupal-site/web/sites/default/settings.php
/drupal-site/web/sites/default/default.services.yml
/drupal-site/web/sites/default/default.settings.php
/drupal-site/web/sites/*/settings.local.php
/drupal-site/web/sites/*/services.local.yml

# ----- Exported config (regenerated by install script: `drush config:export`) -----
# The two deliberately-bad demo files are injected by scripts/inject-bad-config.sh
# after the baseline export. So nothing under config/sync needs to be tracked.
/drupal-site/config/

# ----- Local Drupal data dirs -----
/data/
/db-data/
/.docker-volumes/

# ----- IDE / OS -----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Logs -----
*.log
/logs/

# ----- Private candidate-only docs (never push to public repo) -----
/CANDIDATE_GUIDE.md
/PUSH_GUIDE.md
/NOTES.md
