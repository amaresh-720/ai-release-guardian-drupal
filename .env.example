# AI Release Guardian — Environment Configuration
#
# Copy this file to `.env` and fill in real values. NEVER commit .env.
#
#   cp .env.example .env
#   # edit .env, paste GROQ_API_KEY
#   docker compose up -d --build
#   docker compose exec drupal bash /var/www/html/scripts/install-drupal.sh

# ----- Database -----
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=drupal_dev_pw_change_me
DB_ROOT_PASSWORD=root_dev_pw_change_me

# ----- Drupal site + admin (first-run install only) -----
DRUPAL_SITE_NAME="AI Release Guardian Demo"
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASSWORD=admin
DRUPAL_ADMIN_EMAIL=admin@example.com

# ----- Host port -----
HTTP_PORT=8080

# ----- Groq (LLM provider) -----
# Free key from https://console.groq.com (look for the API Keys page).
# Format starts with `gsk_`.
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
